# Credenciais IQ Option
IQ_EMAIL=seu_email@exemplo.com
IQ_PASSWORD=sua_senha

# PRACTICE (demo) ou REAL
ACCOUNT_TYPE=PRACTICE

# Trading
DEFAULT_STAKE=1
DEFAULT_EXPIRATION=1
MIN_PAYOUT=75

# Martingale (0 = desligado)
MARTINGALE_LEVELS=1
MARTINGALE_FACTOR=2.2

# Stops diários (0 = desligado)
STOP_WIN_DAILY=20
STOP_LOSS_DAILY=15

# Fonte dos sinais do painel Lovable
SIGNALS_URL=https://cheerful-data-glimmer.lovable.app/api/public/signals
POLL_SECONDS=5

# CORS: origem do seu painel (ou * para liberar tudo)
ALLOWED_ORIGINS=*
