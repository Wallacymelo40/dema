# Login da IQ Option — coloque estes valores no Render em Environment.
IQ_EMAIL=seu_email@exemplo.com
IQ_PASSWORD=sua_senha

# Use PRACTICE para teste. Troque para REAL só depois de validar.
ACCOUNT_TYPE=PRACTICE

# Regras de entrada
DEFAULT_STAKE=1
DEFAULT_EXPIRATION=1
MIN_PAYOUT=75

# Martingale: 0 desliga; 1 faz uma tentativa extra; 2 faz duas, etc.
MARTINGALE_LEVELS=0
MARTINGALE_FACTOR=2.2

# Stops diários: 0 desliga
STOP_WIN_DAILY=20
STOP_LOSS_DAILY=15

# URL dos sinais do painel
SIGNALS_URL=https://cheerful-data-glimmer.lovable.app/api/public/signals
POLL_SECONDS=5

# Pode deixar * para teste. Depois, troque pela URL do painel.
ALLOWED_ORIGINS=*
